<Window x:Class="MusicWidget.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Width="960" Height="120"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ShowInTaskbar="False"
        ResizeMode="NoResize"
        Topmost="True">

    <Window.Resources>
        <!-- 半透明黒パネル -->
        <SolidColorBrush x:Key="PanelBrush" Color="#990D0D0D"/>
        <!-- テキスト色 -->
        <SolidColorBrush x:Key="TitleBrush"  Color="#F0F0F0"/>
        <SolidColorBrush x:Key="ArtistBrush" Color="#AAAAAA"/>
        <SolidColorBrush x:Key="AlbumBrush"  Color="#666666"/>
    </Window.Resources>

    <!-- 全体を角丸パネルで囲む -->
    <Border Background="{StaticResource PanelBrush}"
            CornerRadius="6"
            MouseLeftButtonDown="OnDragMove"
            MouseLeftButtonUp="OnDragEnd">
        <Grid>
            <Grid.ColumnDefinitions>
                <!-- アートワーク（正方形120px） -->
                <ColumnDefinition Width="120"/>
                <!-- 情報エリア -->
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- アートワーク -->
            <Border Grid.Column="0"
                    CornerRadius="6 0 0 6"
                    ClipToBounds="True">
                <Image Source="{Binding Artwork}"
                       Stretch="UniformToFill"/>
            </Border>

            <!-- 情報エリア -->
            <Grid Grid.Column="1" Margin="16 14 16 14">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- 楽曲タイトル（右上） -->
                <TextBlock Grid.Row="0"
                       Text="{Binding Title}"
                       Foreground="{StaticResource TitleBrush}"
                       FontSize="36"
                       FontWeight="Medium"
                       VerticalAlignment="Center"
                       TextTrimming="CharacterEllipsis"/>

                <!-- アーティスト・アルバム（右下・横並び） -->
                <StackPanel Grid.Row="1" Orientation="Horizontal">
                    <TextBlock Text="{Binding Artist}"
                           Foreground="{StaticResource ArtistBrush}"
                           FontSize="24"
                           TextTrimming="CharacterEllipsis"/>
                    <TextBlock Text=" — "
                           Foreground="{StaticResource AlbumBrush}"
                           FontSize="24"/>
                    <TextBlock Text="{Binding Album}"
                           Foreground="{StaticResource AlbumBrush}"
                           FontSize="24"
                           TextTrimming="CharacterEllipsis"/>
                </StackPanel>
            </Grid>
        </Grid>
    </Border>
</Window>